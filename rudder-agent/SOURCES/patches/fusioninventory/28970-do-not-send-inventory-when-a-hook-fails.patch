+# Returns (0, $encoded) on success, (2, undef) on failure
+sub _validateJson {
+    my (%params) = @_;
+    my $script   = $params{script};
+    my $output   = $params{output};
+    my $logger   = $params{logger};
+    my $tmp_dir  = $params{tmp_dir};
+    my $package = "JSON::PP";
+    $package->require();
+    if ($EVAL_ERROR) {
+        $logger->error("Failed to load JSON module: $EVAL_ERROR") if $logger;
+        return (2, undef);
+    }
+
+    my $coder = JSON::PP->new;
+    my $encoded;
+    eval {
+        my $decoded = $coder->decode($output);
+        $encoded    = $coder->encode($decoded);
+    };
+    if ($@) {
+        $logger->error("Rudder inventoy hook $script returned invalid JSON: $@") if $logger;
+        my $filename = "$tmp_dir/inventory-json-error-" . time();
+        open(my $fh, '>', $filename);
+        print $fh $output;
+        close($fh);
+        $logger->error("Invalid JSON data stored in $filename") if $logger;
+        return (2, undef);
+    }
+    return (0, $encoded);
+}
+
+# Executes a single script on Windows and validates its JSON output.
+# Returns ($status, $output) where $status is:
+#   0  = success, valid JSON
+#   1  = execution failure
+#   2  = invalid JSON
+sub _executeHookWindows {
+    my (%params) = @_;
+    my $script   = $params{script};
+    my $logger   = $params{logger};
+    $logger->debug("Executing Rudder inventory hook $script") if $logger;
+    my ($exit_code, $output) = eval_timeout(
+        "powershell.exe -file \"$script\"",
+        $hook_timeout
+    );
+    if ($exit_code == -1) {
+        $logger->error("Script $script timed out") if $logger;
+        return (1, undef);
+    }
+    if ($exit_code > 0) {
+        $logger->error("Script $script failed with exit code $exit_code, output: $output") if $logger;
+        return (1, undef);
+    }
+    return _validateJson(script => $script, output => $output, logger => $logger, tmp_dir => 'C:\Program Files\Rudder\tmp');
+}
+# Executes a single script on UNIX and validates its JSON output.
+# Returns ($status, $output) where $status is:
+#   0  = success, valid JSON
+#   1  = execution failure
+#   2  = invalid JSON
+sub _executeHookUnix {
+    my (%params) = @_;
+    my $script   = $params{script};
+    my $logger   = $params{logger};
+
+    unless (-x $script) {
+        $logger->debug("Skipping non-executable hook $script") if $logger;
+        return (1, undef);
+    }
+
+    my $stats       = stat($script);
+    my $owner       = $stats->uid;
+    my $currentUser = $<;
+    if (($owner != 0) && ($owner != $currentUser)) {
+	$logger->error("Skipping $script: not owned by root or current user (owner: $owner)") if $logger;
+        return (1, undef);
+    }
+    my $mode = $stats->mode & 0777;
+    if (($mode & 002) || ($mode & 020)) {
+        $logger->error("Skipping $script: world or group writable") if $logger;
+        return (1, undef);
+    }
+
+    $logger->debug2("Executing Rudder inventory hook $script") if $logger;
+    my ($exit_code, $output) = eval_timeout($script, $hook_timeout);
+    if ($exit_code == -1) {
+        $logger->error("Script $script timed out") if $logger;
+        return (1, undef);
+    }
+    if ($exit_code > 0) {
+        $logger->error("Script $script failed with exit code $exit_code, output: $output") if $logger;
+        return (1, undef);
+    }
+
+    return _validateJson(script => $script, output => $output, logger => $logger, tmp_dir => '/var/rudder/tmp');
+}
